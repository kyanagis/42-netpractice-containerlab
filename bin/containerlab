#!/usr/bin/env bash
set -euo pipefail

if [[ -f /usr/local/lib/np-clab-env.sh ]]; then
  # shellcheck disable=SC1091
  source /usr/local/lib/np-clab-env.sh
elif [[ -f /home/lab/netpractice-containerlab/bin/np-clab-env.sh ]]; then
  # shellcheck disable=SC1091
  source /home/lab/netpractice-containerlab/bin/np-clab-env.sh
elif [[ -f /etc/profile.d/np-clab.sh ]]; then
  # shellcheck disable=SC1091
  source /etc/profile.d/np-clab.sh
fi

REAL_CLAB="${REAL_CLAB:-/usr/bin/containerlab.real}"
CLAB_IMAGE="${CLAB_IMAGE:-ghcr.io/srl-labs/clab:0.75.0}"
REPO_DIR="${REPO_DIR:-/home/lab/netpractice-containerlab}"
DOCKER_SOCKET_HOST="${DOCKER_SOCKET_HOST:-/var/run/docker.sock}"

if [[ "${CLAB_RUN_LOCAL:-0}" = "1" ]]; then
  exec "$REAL_CLAB" "$@"
fi

if declare -F np_clab_prepare_workspace >/dev/null; then
  np_clab_prepare_workspace "$REPO_DIR"
fi

if [[ -z "${NP_CLAB_MOUNT_SOURCE:-}${CLAB_WORKSPACE_VOLUME:-}${HOST_REPO_DIR:-}" ]]; then
  exec "$REAL_CLAB" "$@"
fi

mount_args=()
if [[ -n "${NP_CLAB_MOUNT_SOURCE:-}" ]]; then
  mount_args=(-v "${NP_CLAB_MOUNT_SOURCE}:${NP_CLAB_MOUNT_TARGET:-$REPO_DIR}")
elif [[ -n "${CLAB_WORKSPACE_VOLUME:-}" ]]; then
  mount_args=(-v "${CLAB_WORKSPACE_VOLUME}:${REPO_DIR}")
else
  mount_args=(-v "${HOST_REPO_DIR}:${REPO_DIR}")
fi

workdir="$PWD"
case "$workdir" in
  "$REPO_DIR"|"$REPO_DIR"/*) ;;
  *) workdir="$REPO_DIR" ;;
esac

exec docker run --rm --privileged --network host --pid host \
  -v "${DOCKER_SOCKET_HOST}:/var/run/docker.sock" \
  "${mount_args[@]}" \
  -w "$workdir" \
  "$CLAB_IMAGE" containerlab "$@"
